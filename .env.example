# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg URL used by backend and worker services
DATABASE_URL=postgresql+asyncpg://rosetta:rosetta@localhost:5432/rosetta

# ── Execution backend ─────────────────────────────────────────────────────────
# false = LocalBackend (pandas + PostgreSQL)
# true  = DatabricksBackend (PySpark) — Phase 4, not yet implemented
CLOUD=false

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider and model resolved by Pydantic AI from this string
# Examples: anthropic:claude-sonnet-4-6 | openai:gpt-4o
LLM_MODEL=anthropic:claude-sonnet-4-6

# Provider API keys — only the key matching LLM_MODEL is required
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the browser uses to reach the backend API
VITE_API_URL=http://localhost:8000

# ── TensorZero ───────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint exposed by the TensorZero gateway container
TENSORZERO_GATEWAY_URL=http://tensorzero:3000/openai/v1
# Azure OpenAI credentials (used by TensorZero gateway)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-key-here

# ── Worker ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=5
